{
  "name": "pact-lang",
  "displayName": "PACT Language",
  "description": "Language support for PACT — intent-driven backend language with built-in database",
  "version": "0.1.0",
  "publisher": "kikotvit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KikotVit/pact-lang"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:pact"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "pact",
        "aliases": ["PACT", "pact"],
        "extensions": [".pact"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pact",
        "scopeName": "source.pact",
        "path": "./syntaxes/pact.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  }
}
