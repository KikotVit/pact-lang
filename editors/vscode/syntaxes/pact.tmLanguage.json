{
  "name": "PACT",
  "scopeName": "source.pact",
  "fileTypes": ["pact"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#intent" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#pipeline" },
    { "include": "#effects" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.pact",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.pact",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.pact",
              "match": "\\\\[\"\\\\nrt]"
            },
            {
              "name": "meta.interpolation.pact",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.interpolation.begin.pact" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.interpolation.end.pact" }
              },
              "patterns": [
                { "include": "source.pact" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.pact",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.pact",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.pact",
          "match": "\\b(fn|let|var|if|else|match|return|route|stream|test|check)\\b"
        },
        {
          "name": "keyword.other.pact",
          "match": "\\b(intent|needs|ensure|use|app|assert|respond|send|using)\\b"
        },
        {
          "name": "keyword.operator.logical.pact",
          "match": "\\b(and|or|not|as|is)\\b"
        }
      ]
    },
    "intent": {
      "patterns": [
        {
          "name": "meta.intent.pact",
          "match": "(intent)\\s+(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.other.intent.pact" },
            "2": { "name": "string.quoted.double.intent.pact" }
          }
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.pact",
          "match": "\\b(type)\\b"
        },
        {
          "name": "support.type.primitive.pact",
          "match": "\\b(Int|Float|String|Bool|List|Map|Struct|Nothing|Optional)\\b"
        },
        {
          "name": "entity.name.type.pact",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.pact",
          "match": "\\b(true|false|nothing)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.pact",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.pact",
          "match": "[+\\-*/]"
        },
        {
          "name": "keyword.operator.assignment.pact",
          "match": "="
        },
        {
          "name": "keyword.operator.pipe.pact",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.arrow.pact",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.question.pact",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.spread.pact",
          "match": "\\.\\.\\."
        }
      ]
    },
    "pipeline": {
      "patterns": [
        {
          "name": "keyword.control.pipeline.pact",
          "match": "\\b(filter|where|map|to|sort|by|take|first|last|skip|group|flatten|unique|count|sum|find|expect|one|any|raise|default|success|validate|descending|ascending)\\b(?=\\s)"
        },
        {
          "name": "keyword.control.error-handler.pact",
          "match": "\\bon\\s+\\w+\\s*:"
        }
      ]
    },
    "effects": {
      "patterns": [
        {
          "name": "support.function.builtin.pact",
          "match": "\\b(db|auth|time|rng|log|env|http|request)\\b(?=\\.)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.pact",
          "match": "\\b([a-z_][a-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.pact" }
          }
        }
      ]
    }
  }
}
